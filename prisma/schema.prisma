generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RepositorySourceType {
  GITHUB
  ZIP_UPLOAD
  LOCAL_PATH
}

enum RepositoryStatus {
  PENDING_IMPORT
  IMPORTING
  READY
  IMPORT_FAILED
}

enum ImportJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model ManagedRepository {
  id          String               @id
  ownerId     String
  name        String
  description String?
  sourceType  RepositorySourceType
  sourceUrl   String?
  storagePath String?
  status      RepositoryStatus     @default(PENDING_IMPORT)
  metadata    Json?
  importedAt  DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([ownerId, updatedAt])
}

model RepositoryImportJob {
  id           String          @id
  repositoryId String
  status       ImportJobStatus @default(PENDING)
  currentStep  String          @default("Import requested")
  progress     Int             @default(0)
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?

  @@index([repositoryId, startedAt])
}
