generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RepositorySourceType {
  GITHUB
  ZIP_UPLOAD
  LOCAL_PATH
}

enum RepositoryStatus {
  PENDING_IMPORT
  IMPORTING
  READY
  IMPORT_FAILED
}

enum ImportJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum AnalysisJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model ManagedRepository {
  id          String               @id
  ownerId     String
  name        String
  description String?
  sourceType  RepositorySourceType
  sourceUrl   String?
  storagePath String?
  status      RepositoryStatus     @default(PENDING_IMPORT)
  metadata    Json?
  importedAt  DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([ownerId, updatedAt])
}

model RepositoryImportJob {
  id           String          @id
  repositoryId String
  status       ImportJobStatus @default(PENDING)
  currentStep  String          @default("Import requested")
  progress     Int             @default(0)
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?

  @@index([repositoryId, startedAt])
}

model AnalysisJobRecord {
  id           String            @id
  repositoryId String
  status       AnalysisJobStatus @default(PENDING)
  progress     Int               @default(0)
  currentStep  String
  startedAt    DateTime?
  completedAt  DateTime?
  error        String?
  @@index([repositoryId, startedAt])
}

model CodeFileRecord {
  id           String   @id
  repositoryId String
  path         String
  extension    String
  size         Int
  language     String
  symbols      CodeSymbolRecord[]
  @@unique([repositoryId, path])
  @@index([repositoryId, path])
}

model CodeSymbolRecord {
  id           String   @id
  repositoryId String
  fileId       String
  kind         String
  name         String
  qualifiedName String
  line         Int
  file         CodeFileRecord @relation(fields: [fileId], references: [id], onDelete: Cascade)
  @@index([repositoryId, kind, name])
  @@index([repositoryId, fileId])
}

model CodeRelationshipRecord {
  id             String @id
  repositoryId   String
  sourceSymbolId String
  targetSymbolId String
  kind           String
  confidence     Float
  @@index([repositoryId, sourceSymbolId])
  @@index([repositoryId, targetSymbolId])
}
