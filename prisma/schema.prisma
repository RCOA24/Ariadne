generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RepositorySourceType {
  GITHUB
  ZIP_UPLOAD
  LOCAL_PATH
}

enum RepositoryStatus {
  READY
  ACQUISITION_FAILED
}

model ManagedRepository {
  id          String               @id
  ownerId     String
  name        String
  description String?
  sourceType  RepositorySourceType
  sourceUrl   String?
  storagePath String?
  status      RepositoryStatus     @default(READY)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([ownerId, updatedAt])
}
